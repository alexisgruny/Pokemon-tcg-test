# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pokemon_tcg
DB_USER=postgres
DB_PASSWORD=your_password_here

# Authentication Secrets (Generate strong random values for production)
SESSION_SECRET=generate_secure_random_string_here
